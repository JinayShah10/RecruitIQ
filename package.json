{
  "name": "recruitiq",
  "version": "0.1.0",
  "private": true,
  "description": "AI-Powered Intelligent Recruitment Platform",
  "keywords": [
    "recruitment",
    "ai",
    "hiring",
    "hr-tech",
    "mern"
  ],
  "author": "Jinay Shah",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JinayShah10/RecruitIQ.git"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "build": "npm run build --workspace=frontend",
    "lint": "npm run lint --workspace=frontend && npm run lint --workspace=backend",
    "test": "npm run test --workspace=frontend && npm run test --workspace=backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
